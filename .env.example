# -------- Supabase --------
# Get these from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose this to the browser.
# Required for the embedding pipeline (writes vectors via the service role).
SUPABASE_SERVICE_ROLE_KEY=

# -------- AI providers --------
# Gemini powers default structured extraction (gemini-2.5-flash).
# OpenAI powers streaming chat, idea extraction, rollups, and embeddings
#   (gpt-4.1-mini + text-embedding-3-small, 1536 dims).
# Anthropic is wired for optional Claude-3.5 Haiku extraction.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -------- Optional — local / self-hosted llama.cpp --------
# LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
# LLAMA_CPP_API_KEY=
# LLAMA_CPP_MODEL=
# LLAMA_CPP_EMBEDDING_MODEL=

# -------- App --------
NEXT_PUBLIC_APP_URL=
